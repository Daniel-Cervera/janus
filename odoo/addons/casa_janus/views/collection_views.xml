<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── treea de colecciones ──────────────────────────────────── -->
    <record id="view_collection_tree" model="ir.ui.view">
        <field name="name">casa_janus.collection.tree</field>
        <field name="model">casa_janus.collection</field>
        <field name="arch" type="xml">
            <tree string="Colecciones" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="technique_id"/>
                <field name="slug"/>
                <field name="year_start"/>
                <field name="year_end"/>
                <field name="artwork_count" string="Obras"/>
                <field name="active" widget="toggle_button"/>
            </tree>
        </field>
    </record>

    <!-- ── Formulario de colección ───────────────────────────────── -->
    <record id="view_collection_form" model="ir.ui.view">
        <field name="name">casa_janus.collection.form</field>
        <field name="model">casa_janus.collection</field>
        <field name="arch" type="xml">
            <form string="Colección">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre de la colección"/>
                        <h1>
                            <field name="name" placeholder="Ej: Sombras Mediterráneas"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="technique_id"/>
                            <field name="slug" placeholder="sombras-mediterraneas"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="year_start" placeholder="2020"/>
                            <field name="year_end" placeholder="2023"/>
                            <field name="artwork_count" string="Obras"/>
                            <field name="cover_cf_image_id"
                                   string="ID imagen portada (Cloudflare)"
                                   placeholder="uuid de Cloudflare Images"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1"
                               placeholder="Descripción de la colección para el sitio web..."/>
                    </group>
                    <notebook>
                        <page string="Obras" name="artworks">
                            <field name="artwork_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="year"/>
                                    <field name="medium"/>
                                    <field name="availability"
                                           widget="badge"
                                           decoration-success="availability == 'available'"
                                           decoration-danger="availability == 'sold'"
                                           decoration-warning="availability == 'reserved'"/>
                                    <field name="price"/>
                                    <field name="active" widget="toggle_button"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Búsqueda ──────────────────────────────────────────────── -->
    <record id="view_collection_search" model="ir.ui.view">
        <field name="name">casa_janus.collection.search</field>
        <field name="model">casa_janus.collection</field>
        <field name="arch" type="xml">
            <search string="Buscar colecciones">
                <field name="name"/>
                <field name="technique_id"/>
                <filter name="active" string="Activas" domain="[('active','=',True)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_technique" string="Técnica"
                            context="{'group_by': 'technique_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Acción ─────────────────────────────────────────────────── -->
    <record id="action_collection" model="ir.actions.act_window">
        <field name="name">Colecciones</field>
        <field name="res_model">casa_janus.collection</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera colección
            </p>
            <p>
                Las colecciones agrupan obras dentro de una técnica.
                Ej: "Sombras Mediterráneas" dentro de Óleo.
            </p>
        </field>
    </record>

</odoo>
