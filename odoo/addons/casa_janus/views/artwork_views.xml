<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_artwork_kanban" model="ir.ui.view">
        <field name="name">casa_janus.artwork.kanban</field>
        <field name="model">casa_janus.artwork</field>
        <field name="arch" type="xml">
            <kanban default_group_by="collection_id">
                <field name="name"/>
                <field name="year"/>
                <field name="availability"/>
                <field name="price"/>
                <field name="currency_id"/>
                <field name="is_featured"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <t t-if="record.is_featured.raw_value">
                                    <span class="badge text-bg-warning">★</span>
                                </t>
                            </div>
                            <div class="oe_kanban_details">
                                <small class="text-muted mr-2">
                                    <field name="year" options="{'format': 0}"/>
                                </small>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="availability" widget="badge" decoration-success="availability == 'available'" decoration-danger="availability == 'sold'" decoration-warning="availability == 'reserved'"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <t t-if="record.price.raw_value">
                                        <field name="price"/>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_artwork_tree" model="ir.ui.view">
        <field name="name">casa_janus.artwork.tree</field>
        <field name="model">casa_janus.artwork</field>
        <field name="arch" type="xml">
            <tree string="Obras" decoration-muted="availability == 'sold'" decoration-success="availability == 'available'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="technique_id" string="Técnica"/>
                <field name="collection_id" string="Colección"/>
                <field name="year"/>
                <!-- <field name="medium"/> -->
                <field name="price"/>
                <field name="availability" widget="badge" decoration-success="availability == 'available'" decoration-danger="availability == 'sold'" decoration-warning="availability == 'reserved'"/>
                <field name="is_featured" widget="boolean_toggle" string="★"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_artwork_form" model="ir.ui.view">
        <field name="name">casa_janus.artwork.form</field>
        <field name="model">casa_janus.artwork</field>
        <field name="arch" type="xml">
            <form string="Obra de Arte">
                <header>
                    <field name="availability" widget="statusbar" statusbar_visible="available,reserved,sold,nfs"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Destacada" bg_color="bg-warning" invisible="not is_featured"/>
                    <div class="oe_title">
                        <label for="name" string="Título de la obra"/>
                        <h1>
                            <field name="name" placeholder="Título de la obra"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Clasificación">
                            <field name="artist_id" options="{'no_create': True}"/>
                            <field name="collection_id"/>
                            <field name="technique_id" readonly="True"/>
                            <field name="year"/>
                            <field name="slug" placeholder="titulo-obra-2024"/>
                            <field name="sequence"/>
                            <field name="is_featured"/>
                            <field name="active"/>
                        </group>
                        <group string="Datos técnicos">
                            <field name="medium" placeholder="Ej: Óleo sobre lino"/>
                            <label for="height_cm" string="Dimensiones (cm)"/>
                            <div class="o_row">
                                <field name="height_cm" placeholder="Alto" nolabel="1"/>
                                <span> × </span>
                                <field name="width_cm" placeholder="Ancho" nolabel="1"/>
                                <span> × </span>
                                <field name="depth_cm" placeholder="Prof." nolabel="1"/>
                            </div>
                            <field name="edition_number" string="Núm. ejemplar"/>
                            <field name="edition_total" string="Tiraje total"/>
                            <field name="edition_display" string="Edición" readonly="True"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1" placeholder="Descripción para el sitio web..."/>
                    </group>
                    <group string="Comercial">
                        <group>
                            <field name="price"/>
                            <field name="currency_id"/>
                            <field name="availability"/>
                        </group>
                    </group>
                    <group string="Imagen principal (Cloudflare Images)">
                        <field name="primary_cf_image_id" string="Cloudflare Image ID" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
                    </group>
                    <notebook>
                        <page string="Imágenes adicionales" name="images">
                            <field name="image_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="cf_image_id" string="Cloudflare Image ID"/>
                                    <field name="is_primary" string="Principal"/>
                                    <field name="alt_text" string="Alt text"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Prints" name="prints">
                            <field name="print_product_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="size_label"/>
                                    <field name="paper_type"/>
                                    <field name="price"/>
                                    <field name="stock_qty"/>
                                </tree>
                            </field>
                        </page>
                        <page string="SEO" name="seo">
                            <group>
                                <field name="meta_title"/>
                                <field name="meta_description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_artwork_search" model="ir.ui.view">
        <field name="name">casa_janus.artwork.search</field>
        <field name="model">casa_janus.artwork</field>
        <field name="arch" type="xml">
            <search string="Buscar obras">
                <field name="name"/>
                <field name="technique_id"/>
                <field name="collection_id"/>
                <filter name="available" string="Disponibles" domain="[('availability','=','available')]"/>
                <filter name="featured" string="Destacadas" domain="[('is_featured','=',True)]"/>
                <separator/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_collection" string="Colección" context="{'group_by': 'collection_id'}"/>
                    <filter name="group_technique" string="Técnica" context="{'group_by': 'technique_id'}"/>
                    <filter name="group_year" string="Año" context="{'group_by': 'year'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_artwork" model="ir.actions.act_window">
        <field name="name">Obras</field>
        <field name="res_model">casa_janus.artwork</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Agrega tu primera obra
            </p>
            <p>Crea primero una Técnica y una Colección.</p>
        </field>
    </record>

</odoo>
